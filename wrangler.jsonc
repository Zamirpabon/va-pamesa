{
  // Config para desplegar va·pa·mesa en Cloudflare (Workers con assets estáticos).
  // Sirve la carpeta dist/ que genera `npm run build`.
  "name": "va-pamesa",
  "compatibility_date": "2025-09-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
