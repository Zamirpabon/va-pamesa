# Copia este archivo como ".env" y pega tus datos de Supabase.
# Los encuentras en: Supabase → Project Settings → API
#  - Project URL          -> VITE_SUPABASE_URL
#  - Project API keys -> anon public -> VITE_SUPABASE_ANON_KEY
#
# (La llave "anon" es pública y segura para el front: la seguridad la
#  imponen las políticas RLS de la base de datos.)

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU-LLAVE-ANON-PUBLICA
